<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground: two intersecting circles + an X marking the
  collision, mirroring docs/design/assets/colision-app-icon.svg. Drawn inside
  the 72×72 safe zone centered on the 108×108 adaptive canvas (so the OS mask —
  circle, squircle, etc. — never clips the mark).
  Stroke off-white (#FAF7F2, tokens.jsx).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Left circle, center (45, 54), radius 15.75 -->
    <path
        android:pathData="M29.25,54 a15.75,15.75 0 1,0 31.5,0 a15.75,15.75 0 1,0 -31.5,0"
        android:strokeColor="#FAF7F2"
        android:strokeWidth="3.375"
        android:fillColor="#00000000" />
    <!-- Right circle, center (63, 54), radius 15.75 -->
    <path
        android:pathData="M47.25,54 a15.75,15.75 0 1,0 31.5,0 a15.75,15.75 0 1,0 -31.5,0"
        android:strokeColor="#FAF7F2"
        android:strokeWidth="3.375"
        android:fillColor="#00000000" />
    <!-- X, two diagonals across the overlap -->
    <path
        android:pathData="M46.125,48.375 L61.875,59.625"
        android:strokeColor="#FAF7F2"
        android:strokeWidth="3.375"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
    <path
        android:pathData="M46.125,59.625 L61.875,48.375"
        android:strokeColor="#FAF7F2"
        android:strokeWidth="3.375"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
</vector>
